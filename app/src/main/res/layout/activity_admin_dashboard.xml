<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Dashboard"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active Service Requests:"
            android:textStyle="bold" />

        <!-- Fixed height for lists to allow scrolling in the main view -->
        <ListView
            android:id="@+id/lv_requests"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#F0F0F0"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage Services (Add/Remove):"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_new_service_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Service Code (e.g., CL002)" />

        <EditText
            android:id="@+id/et_new_service_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Service Name" />

        <Button
            android:id="@+id/btn_add_service"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add New Service" />

        <ListView
            android:id="@+id/lv_services"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="10dp"
            android:background="#E8E8E8" />
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="User Management (Click to Delete):"
            android:textStyle="bold" />

        <ListView
            android:id="@+id/lv_users"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="#E8E8E8" />

    </LinearLayout>
</ScrollView>